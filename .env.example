# EvoLink — when EVOLINK_API_KEY is set, /api/generate-design routes through
# EvoLink (https://evolink.ai) instead of Google. nano-banana-beta is the
# cheap/dev tier of Gemini 2.5 Flash Image; use "nano-banana" for 99.9% uptime.
EVOLINK_API_KEY=
EVOLINK_MODEL=nano-banana-beta

# Google direct (fallback provider when EVOLINK_API_KEY is unset)
GEMINI_API_KEY=
NANO_BANANA_MODEL=gemini-3.1-flash-image

# Supabase — safe to expose to the browser (Vite inlines VITE_* at build time).
# Access control is enforced by Supabase Row Level Security policies, not by
# hiding this key. Used for permanent Project Type persistence (see
# src/lib/supabase.js and src/services/projectTypesService.js).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only — never prefix with VITE_. Used by api/_lib/supabaseAdmin.js
# to bypass RLS for generation logs, registrations, and suppliers.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only admin passcode, checked in api/admin-login.js. Replaces the
# passcode that used to be hardcoded in the client bundle.
ADMIN_PASSCODE=
